# BeProduct API credentials
# Request client credentials from BeProduct Support: support@beproduct.com
BEPRODUCT_CLIENT_ID=your_client_id_here
BEPRODUCT_CLIENT_SECRET=your_client_secret_here

# Obtain your refresh token by running: python scripts/get_refresh_token.py
BEPRODUCT_REFRESH_TOKEN=your_refresh_token_here

# Your company domain from BeProduct URL, e.g. https://us.beproduct.com/YourCompany/Home
BEPRODUCT_COMPANY_DOMAIN=YourCompanyDomain

# Callback URL registered with BeProduct support (used during token bootstrap only)
BEPRODUCT_CALLBACK_URL=http://localhost:8765/callback

# Sync settings
SYNC_INTERVAL_MINUTES=15

# Local database path (relative to project root)
DB_PATH=data/beproduct.db
